# --- Cliente (exposto no browser; use só chaves PÚBLICAS) ---
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=ou_VITE_SUPABASE_PUBLISHABLE_KEY

# URL pública do app (produção Lovable ou domínio próprio). Usada em convites por e-mail (server):
# redirect pós-login → {PUBLIC_APP_URL}/app
# No Supabase: Authentication → URL Configuration → adicione https://signix-display-pro.lovable.app e https://signix-display-pro.lovable.app/app
PUBLIC_APP_URL=https://signix-display-pro.lovable.app
# Opcional (alias exposto no build): VITE_PUBLIC_APP_URL=https://signix-display-pro.lovable.app

# --- Servidor (SSR / server functions TanStack Start) — NÃO use prefixo VITE_ ---
# Copie o URL do projeto: Supabase → Project Settings → API → Project URL
SUPABASE_URL=https://SEU-PROJETO.supabase.co
# Service role: mesma página → "service_role" (secret). NUNCA comitar nem expor no frontend.
# Aceita qualquer um dos nomes abaixo:
SERVICE_ROLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Asaas (Edge Functions: create-checkout-session, payment-webhook) ---
# Crie a chave em: Integrações → chave de API (sandbox e produção são distintas).
# Defina as mesmas chaves em Supabase → Project Settings → Edge Functions → Secrets.
# ASAAS_API_KEY=$aact_...
# API sandbox: https://api-sandbox.asaas.com  |  produção: https://api.asaas.com
# ASAAS_API_BASE=https://api-sandbox.asaas.com
# Token que o Asaas envia no header "asaas-access-token" (configure o mesmo no painel do webhook do Asaas).
# ASAAS_WEBHOOK_TOKEN=seu_token_secreto_32_ou_mais_caracteres

# --- Edge Functions (Secrets no Supabase; ver docs/SECURITY_AUDIT_SIGPLAYER.md) ---
# Lista de origins ou * mantém CORS permissivo até definir lista (ex.: https://app.example.com).
# FUNCTIONS_ALLOWED_ORIGINS=
# Produção quando todos os players usam auth de dispositivo:
# DENY_LEGACY_SCREEN_UUID_RESOLVE=true
