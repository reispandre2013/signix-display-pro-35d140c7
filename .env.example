SUPABASE_URL=https://SEU-PROJETO.supabase.co
# Service role: mesma página → "service_role" (secret). NUNCA comitar nem expor no frontend.
# Aceita qualquer um dos nomes abaixo:
SERVICE_ROLE_KEY=
