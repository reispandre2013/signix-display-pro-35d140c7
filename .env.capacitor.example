# Copie para .env.capacitor. Usado por capacitor.config.ts em `npx cap sync android`.
#
# Recomendado — fluxo com código na TV (igual player Tizen nativo):
#   /pareamento?platform=tizen   (Samsung Tizen no WebView / TV browser)
#   /pareamento?platform=android (Android TV / box)
# Depois do pareamento no painel, o utilizador pode abrir /player-screen na mesma origem.
#
CAPACITOR_SERVER_URL=https://signix-stream.lovable.app/pareamento?platform=android
